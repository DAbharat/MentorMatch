generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkUserId String   @unique 
  email     String   @unique
  name      String
  bio       String?
  createdAt DateTime @default(now())

  averageRating Float?
  ratingCount   Int @default(0)

  skillsOffered Skill[] @relation("OfferedSkills")
  skillsWanted  Skill[] @relation("WantedSkills")

  sessionsAsMentor Session[] @relation("Mentor")
  sessionsAsMentee Session[] @relation("Mentee")

  mentorshipRequestsReceived MentorshipRequest[] @relation("MentorRequests")
  mentorshipRequestsSent     MentorshipRequest[] @relation("MenteeRequests")

  chatsAsMentor Chat[] @relation("MentorChats")
  chatsAsMentee Chat[] @relation("MenteeChats")

  messages Message[]

  callEvents CallEvent[]

  feedbackReceived UserFeedback[] @relation("MentorFeedback")
  feedbackGiven    UserFeedback[] @relation("MenteeFeedback")

  notifications Notification[] @relation("UserNotifications")
  notificationsSent Notification[] @relation("SenderNotifications")

  @@index([email, id])
}


model Skill {
  id   String @id @default(uuid())
  name String @unique
  normalizedSkillName String @unique

  offeredBy User[] @relation("OfferedSkills")
  wantedBy  User[] @relation("WantedSkills")

  sessions Session[]

  feedback UserFeedback[]

  mentorshipRequests MentorshipRequest[]
  chats Chat[] @relation("SkillChats")
}

model Session {
  id String @id @default(uuid())

  mentorId String
  menteeId String
  skillId  String

  mentor User  @relation("Mentor", fields: [mentorId], references: [id])
  mentee User  @relation("Mentee", fields: [menteeId], references: [id])
  skill  Skill @relation(fields: [skillId], references: [id])

  mentorshipRequestId String?
  mentorshipRequest   MentorshipRequest? @relation(fields: [mentorshipRequestId], references: [id])

  scheduledAt DateTime

  status SessionStatus @default(PENDING)

  feedback UserFeedback?

  completedBy SessionCompletedBy? 

  roomId            String @unique
  callStartedAt     DateTime?
  callEndedAt       DateTime?
  totalCallDuration Int?

  mentorActiveMinutes Int?
  menteeActiveMinutes Int?
  totalActiveMinutes  Int?

  metricsComputedAt DateTime?

  createdAt DateTime @default(now())

  callEvents CallEvent[]

  @@index([mentorId])
  @@index([menteeId])
  @@index([skillId])
  @@index([mentorshipRequestId])
  @@index([scheduledAt])
  @@index([status, callStartedAt, metricsComputedAt])
}


enum SessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionCompletedBy {
  Mentor
  Auto
}

model UserFeedback {
  id String @id @default(uuid())

  mentorId String
  mentor   User   @relation("MentorFeedback", fields: [mentorId], references: [id])

  menteeId String
  mentee   User   @relation("MenteeFeedback", fields: [menteeId], references: [id])

  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id])

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id])

  rating  Int
  comment String

  confidenceBefore Int?
  confidenceAfter  Int?

  createdAt DateTime @default(now())

  @@index([mentorId])
  @@index([menteeId])
  @@index([sessionId])
}

model MentorshipRequest {
  id String @id @default(uuid())

  mentorId String
  mentor   User   @relation("MentorRequests", fields: [mentorId], references: [id])

  menteeId String
  mentee   User   @relation("MenteeRequests", fields: [menteeId], references: [id])

  sessions Session[]

  initialMessage String?

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id])

  status MentorshipRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mentorId])
  @@index([menteeId])
  @@index([skillId])
}

enum MentorshipRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Chat {
  id String @id @default(uuid())

  mentorId String
  menteeId String
  skillId  String

  mentor User @relation("MentorChats", fields: [mentorId], references: [id])
  mentee User @relation("MenteeChats", fields: [menteeId], references: [id])
  skill Skill @relation("SkillChats", fields: [skillId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())

  @@unique([mentorId, menteeId, skillId])
}

model Message {
  id String @id @default(uuid())

  chatId String
  chat   Chat @relation(fields: [chatId], references: [id])

  senderId String
  sender   User @relation(fields: [senderId], references: [id])

  content String

  isDelivered Boolean @default(false)
  isRead      Boolean @default(false)
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}

model CallEvent {
  id String @id @default(uuid())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventType CallEventType
  timestamp DateTime      @default(now())

  @@index([sessionId])
  @@index([userId])
}

enum CallEventType {
  JOINED
  LEFT
  DISCONNECTED
}

model Notification {
  id String @id @default(uuid())

  userId String
  user User @relation("UserNotifications", fields: [userId], references: [id])

  senderId String?           
  sender   User? @relation("SenderNotifications", fields: [senderId], references: [id])

  type NotificationType

  title String
  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt, isRead])
}

enum NotificationType {
  MENTORSHIP_REQUEST_RECEIVED
  MENTORSHIP_REQUEST_SENT
  MENTORSHIP_REQUEST_ACCEPTED
  MENTORSHIP_REQUEST_REJECTED
  SESSION_SCHEDULED
  SESSION_CONFIRMED
  SESSION_STARTED
  SESSION_CANCELLED
  SESSION_REMINDER
  FEEDBACK_RECEIVED
  FEEDBACK_SENT
}