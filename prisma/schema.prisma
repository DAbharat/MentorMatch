generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  averageRating Float?
  ratingCount   Int @default(0)

  skillsOffered Skill[] @relation("OfferedSkills")
  skillsWanted  Skill[] @relation("WantedSkills")

  sessionsAsMentor Session[] @relation("Mentor")
  sessionsAsMentee Session[] @relation("Mentee")

  mentorshipRequestsReceived MentorshipRequest[] @relation("MentorRequests")
  mentorshipRequestsSent     MentorshipRequest[] @relation("MenteeRequests")

  chatsAsMentor Chat[] @relation("MentorChats")
  chatsAsMentee Chat[] @relation("MenteeChats")

  messages Message[]

  callEvents CallEvent[]

  feedbackReceived UserFeedback[] @relation("MentorFeedback")
  feedbackGiven    UserFeedback[] @relation("MenteeFeedback")
}


model Skill {
  id   String @id @default(uuid())
  name String @unique

  offeredBy User[] @relation("OfferedSkills")
  wantedBy  User[] @relation("WantedSkills")

  sessions Session[]
}

model Session {
  id String @id @default(uuid())

  mentorId String
  menteeId String
  skillId  String

  mentor User  @relation("Mentor", fields: [mentorId], references: [id])
  mentee User  @relation("Mentee", fields: [menteeId], references: [id])
  skill  Skill @relation(fields: [skillId], references: [id])

  scheduledAt DateTime

  status SessionStatus @default(PENDING)

  feedback UserFeedback?

  completedBy Role? 

  roomId            String @unique
  callStartedAt     DateTime?
  callEndedAt       DateTime?
  totalCallDuration Int?

  createdAt DateTime @default(now())

  callEvents CallEvent[]

  @@index([mentorId])
  @@index([menteeId])
  @@index([skillId])
  @@index([scheduledAt])
}


enum SessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Role {
  Mentor
  Auto
}

model UserFeedback {
  id String @id @default(uuid())

  mentorId String
  mentor   User   @relation("MentorFeedback", fields: [mentorId], references: [id])

  menteeId String
  mentee   User   @relation("MenteeFeedback", fields: [menteeId], references: [id])

  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id])

  rating  Int
  comment String?

  confidenceBefore Int?
  confidenceAfter  Int?

  createdAt DateTime @default(now())

  @@index([mentorId])
  @@index([menteeId])
  @@index([sessionId])
  @@unique([mentorId, menteeId])
}

model MentorshipRequest {
  id String @id @default(uuid())

  mentorId String
  mentor   User   @relation("MentorRequests", fields: [mentorId], references: [id])

  menteeId String
  mentee   User   @relation("MenteeRequests", fields: [menteeId], references: [id])

  initialMessage String?

  status MentorshipRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mentorId, menteeId])
  @@index([mentorId])
  @@index([menteeId])
}

enum MentorshipRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Chat {
  id String @id @default(uuid())

  mentorId String
  menteeId String

  mentor User @relation("MentorChats", fields: [mentorId], references: [id])
  mentee User @relation("MenteeChats", fields: [menteeId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())

  @@unique([mentorId, menteeId])
}

model Message {
  id String @id @default(uuid())

  chatId String
  chat   Chat @relation(fields: [chatId], references: [id])

  senderId String
  sender   User @relation(fields: [senderId], references: [id])

  content String

  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([senderId])
}

model CallEvent {
  id String @id @default(uuid())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventType CallEventType
  timestamp DateTime      @default(now())

  @@index([sessionId])
  @@index([userId])
}

enum CallEventType {
  JOINED
  LEFT
  DISCONNECTED
}
